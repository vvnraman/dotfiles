#######
# Shell
#######
command = fish --login --interactive
shell-integration = none

#######
# fonts
#######

# Default is "JetBrains Mono"
font-family = MesloLGS Nerd Font Mono
font-size = 11

#######
# theme
#######
# theme = Spacedust
