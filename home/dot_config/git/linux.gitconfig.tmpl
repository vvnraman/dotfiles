# vim: ft=gitconfig
[include]
    path = ~/.config/git/user-{{ template "user-config.tmpl" . }}.gitconfig
{{ if findExecutable "delta" (list "$HOME/.local/bin" "/usr/local/bin" "/usr/bin") }}
    path = ~/.config/git/tool-delta.gitconfig
{{ end }}
{{ if findExecutable "kdiff3" (list "$HOME/.local/bin" "/usr/local/bin" "/usr/bin") }}
    path = ~/.config/git/tool-kdiff3.gitconfig
{{ end }}

[push]
    default = simple

[core]
    excludesfile = ~/.config/git/global.gitignore

