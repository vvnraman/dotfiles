#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$script_dir/nvim.env"

reset_data=false
for arg in "$@"; do
  if [[ "$arg" == "--reset" ]]; then
    reset_data=true
  else
    echo "error: unknown argument '$arg'" >&2
    echo "usage: $0 [--reset]" >&2
    exit 2
  fi
done

vvn_export_nvim_env "$script_dir"
nvim_appname="$NVIM_APPNAME"

: "${NVIM_TREESITTER_SYNC_INSTALL:=1}"
export NVIM_TREESITTER_SYNC_INSTALL

if [[ "$reset_data" == true ]]; then
  data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  data_dir="${data_home:?}/${nvim_appname:?}"
  state_dir="${state_home:?}/${nvim_appname:?}"

  if [[ ! -d "$data_dir" ]]; then
    echo "error: NVIM data directory not found: '$data_dir'" >&2
    exit 1
  fi
  if [[ ! -d "$state_dir" ]]; then
    echo "error: NVIM state directory not found: '$state_dir'" >&2
    exit 1
  fi

  rm -rf -- "$data_dir" "$state_dir"
fi

env \
  NVIM_APPNAME="$NVIM_APPNAME" \
  NVIM_PROFILE="$NVIM_PROFILE" \
  NVIM_TREESITTER_SYNC_INSTALL="$NVIM_TREESITTER_SYNC_INSTALL" \
  /usr/bin/nvim --headless "+Lazy! restore" "+Lazy! load nvim-treesitter" +qall
