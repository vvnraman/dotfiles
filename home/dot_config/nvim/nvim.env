#!/usr/bin/env bash

set -euo pipefail

vvn_resolve_nvim_appname() {
  local script_dir="$1"
  local config_home

  config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  config_home="$(realpath "$config_home")"

  case "$script_dir" in
  "$config_home"/*)
    printf '%s\n' "${script_dir#"$config_home"/}"
    ;;
  *)
    echo "error: script directory '$script_dir' is not under '$config_home'" >&2
    return 1
    ;;
  esac
}

vvn_export_nvim_env() {
  local script_dir="$1"

  export NVIM_APPNAME
  NVIM_APPNAME="$(vvn_resolve_nvim_appname "$script_dir")"

  : "${VVN_NVIM_PROFILE:=standard}"
  export VVN_NVIM_PROFILE
}
