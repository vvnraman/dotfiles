#!/usr/bin/env bash
# vim: set filetype=sh : */

_MG_BIN_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
_MG_HOME_DIR="$(dirname "${_MG_BIN_DIR}")"

if [[ ! -f "${_MG_HOME_DIR}/lib/bash-lib.sh" ]]; then
  echo "Unable to locate bash lib: ${_MG_HOME_DIR}/lib/bash-lib.sh"
  if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    return 1
  fi
  exit 1
fi

# shellcheck source=/dev/null
. "${_MG_HOME_DIR}/lib/bash-lib.sh"

if [[ ! -f "${_MG_BIN_DIR}/my-git/git-lib.sh" ]]; then
  echo "Unable to locate git lib: ${_MG_BIN_DIR}/my-git/git-lib.sh"
  if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    return 1
  fi
  exit 1
fi

# shellcheck source=/dev/null
. "${_MG_BIN_DIR}/my-git/git-lib.sh"


function _set_main_subcommands() {
  local -n out_subcommands="${1}"

  out_subcommands=(
    update-commit-date
    init
    clone
    show-ignored
    show-untracked
    switch
    new-branch
    self-branch
    alien-branch
    info
    path
    remove-worktree
    remove-branch
    prune
  )
}

function _resolve_subcommand_alias() {
  local subcommand="${1}"

  case "${subcommand}" in
  u)
    printf '%s\n' 'update-commit-date'
    ;;
  c)
    printf '%s\n' 'clone'
    ;;
  s)
    printf '%s\n' 'switch'
    ;;
  n)
    printf '%s\n' 'new-branch'
    ;;
  b)
    printf '%s\n' 'self-branch'
    ;;
  i)
    printf '%s\n' 'info'
    ;;
  rb)
    printf '%s\n' 'remove-branch'
    ;;
  rw)
    printf '%s\n' 'remove-worktree'
    ;;
  *)
    printf '%s\n' "${subcommand}"
    ;;
  esac
}

function _main_subcommand_display_name() {
  local subcommand="${1}"

  case "${subcommand}" in
  update-commit-date)
    printf '%s\n' 'update-commit-date | u'
    ;;
  clone)
    printf '%s\n' 'clone | c'
    ;;
  switch)
    printf '%s\n' 'switch | s'
    ;;
  new-branch)
    printf '%s\n' 'new-branch | n'
    ;;
  self-branch)
    printf '%s\n' 'self-branch | b'
    ;;
  info)
    printf '%s\n' 'info | i'
    ;;
  remove-branch)
    printf '%s\n' 'remove-branch | rb'
    ;;
  remove-worktree)
    printf '%s\n' 'remove-worktree | rw'
    ;;
  *)
    printf '%s\n' "${subcommand}"
    ;;
  esac
}

function _main_subcommand_short_description() {
  local subcommand="${1}"

  case "${subcommand}" in
  update-commit-date)
    printf '%s\n' 'Amend current commit date to now.'
    ;;
  init)
    printf '%s\n' 'Create a bare+worktree repository layout for <project>.'
    ;;
  clone)
    printf '%s\n' 'Clone into managed bare/worktree layout.'
    ;;
  show-ignored)
    printf '%s\n' 'List ignored files.'
    ;;
  show-untracked)
    printf '%s\n' 'List untracked files.'
    ;;
  switch)
    printf '%s\n' 'Switch to an existing branch worktree. Does not create new branches.'
    ;;
  new-branch)
    printf '%s\n' 'Create a new branch worktree, defaulting base to current branch.'
    ;;
  self-branch)
    printf '%s\n' 'Create tracked worktree branch <branch> from existing <remote>.'
    ;;
  alien-branch)
    printf '%s\n' 'Create tracked worktree branch <remote>_<branch> from existing <remote>.'
    ;;
  info)
    printf '%s\n' 'Show layout kind, worktree paths, remotes, and branch tracking.'
    ;;
  path)
    printf '%s\n' 'Print managed worktree path for <branch>.'
    ;;
  remove-worktree)
    printf '%s\n' 'Remove a worktree only, keeping local branch refs.'
    ;;
  remove-branch)
    printf '%s\n' 'Remove merged branch worktree and local branch.'
    ;;
  prune)
    printf '%s\n' 'Prune remotes and stale worktree metadata.'
    ;;
  help)
    printf '%s\n' 'Show this help text.'
    ;;
  *)
    return 1
    ;;
  esac
}

function _usage_main_short() {
  local -a help_commands=()
  local help_command
  local label_width=0
  local command_label

  _set_main_subcommands help_commands

  printf '%s\n' 'Usage: mg <command> [args]'
  printf '\n'
  printf '%s\n' 'Commands:'

  for help_command in "${help_commands[@]}"; do
    command_label="$(_main_subcommand_display_name "${help_command}")"
    if [[ ${#command_label} -gt ${label_width} ]]; then
      label_width=${#command_label}
    fi
  done

  command_label="help"
  if [[ ${#command_label} -gt ${label_width} ]]; then
    label_width=${#command_label}
  fi

  for help_command in "${help_commands[@]}"; do
    printf "  %-*s - %s\n" "${label_width}" "$(_main_subcommand_display_name "${help_command}")" "$(_main_subcommand_short_description "${help_command}")"
  done
  printf "  %-*s - %s\n" "${label_width}" "help" "$(_main_subcommand_short_description help)"
}

function _usage_main() {
  local short_output=0

  while [[ $# -gt 0 ]]; do
    case "${1}" in
    --short | --short-help | -h)
      short_output=1
      ;;
    *)
      echo "Unknown help option: ${1}"
      return 1
      ;;
    esac
    shift
  done

  if [[ "${short_output}" -eq 1 ]]; then
    _usage_main_short
    return 0
  fi

  cat <<'EOF'
Usage: mg <command> [args]

Commands:
  help [--short] [--short-help] [-h] | --help [--short] [--short-help] [-h]
  -h | --short-help
      Show this help text.

  Aliases: u=update-commit-date, c=clone, s=switch, n=new-branch,
           b=self-branch, i=info, rb=remove-branch, rw=remove-worktree.

EOF

  local -a help_commands=()
  local help_command

  _set_main_subcommands help_commands

  for help_command in "${help_commands[@]}"; do
    _load_subcommand_script "${help_command}" || return 1
  done

  _usage_update_commit_date
  _usage_init
  _usage_clone
  _usage_show_ignored
  _usage_show_untracked
  _usage_switch
  _usage_new_branch
  _usage_self_branch
  _usage_alien_branch
  _usage_info
  _usage_path
  _usage_remove_worktree
  _usage_remove_branch
  _usage_prune

  cat <<'EOF'
Options:
  --host <host-alias>
      Supported by: clone only.

  --dest <project-dir>
      Supported by: clone only.

Defaults:
  Host defaults to VVN_DOTFILES_GITHUB_HOST; fallback is github.

Host aliases:
  <host-alias> is your SSH host alias from ~/.ssh/config
  (for example: github -> github.com with User git).
  Show resolved hostname for alias:
    ssh -G github | rg '^hostname '
EOF
}

function _print_completion_metadata() {
  cat <<'EOF'
cmd|update-commit-date|u
cmd|init|
cmd|clone|c
cmd|show-ignored|
cmd|show-untracked|
cmd|switch|s
cmd|new-branch|n
cmd|self-branch|b
cmd|alien-branch|
cmd|info|i
cmd|path|
cmd|remove-branch|rb
cmd|remove-worktree|rw
cmd|prune|
cmd|help|
opts|update-commit-date|--example
opts|init|--help,--example
opts|clone|--host,--dest,--help,--example
opts|show-ignored|--example
opts|show-untracked|--example
opts|switch|--example
opts|new-branch|--from,--help,--example
opts|self-branch|--help,--example
opts|alien-branch|--help,--example
opts|info|--help,--example
opts|path|--help,--example
opts|remove-branch|--force,--help,--example
opts|remove-worktree|--force,--help,--example
opts|prune|--help,--example
opts|help|--short,--short-help
branch|switch|1|all
branch|new-branch|1|all
branch|path|1|all
branch|remove-branch|1|all
branch|remove-worktree|1|all
remote|self-branch|1
remote|alien-branch|1
remote-branch|self-branch|2
remote-branch|alien-branch|2
value-opt|clone|--host
value-opt|clone|--dest
value-opt|new-branch|--from
EOF
}

declare -A _MG_INCLUDE_GUARD_SUBCOMMAND_SCRIPTS

# Resolve a command name to its script path.
# Keep this mapping in sync with `my-git/cmd-*.sh` filenames.
function _subcommand_script_path() {
  local subcommand="${1}"

  case "${subcommand}" in
  update-commit-date)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-update-commit-date.sh"
    ;;
  init)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-init.sh"
    ;;
  clone)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-clone.sh"
    ;;
  show-ignored)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-show-ignored.sh"
    ;;
  show-untracked)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-show-untracked.sh"
    ;;
  switch)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-switch.sh"
    ;;
  new-branch)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-new-branch.sh"
    ;;
  self-branch)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-self-branch.sh"
    ;;
  alien-branch)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-alien-branch.sh"
    ;;
  info)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-info.sh"
    ;;
  path)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-path.sh"
    ;;
  remove-worktree)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-remove-worktree.sh"
    ;;
  remove-branch)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-remove-branch.sh"
    ;;
  prune)
    printf '%s\n' "${_MG_BIN_DIR}/my-git/cmd-prune.sh"
    ;;
  *)
    return 1
    ;;
  esac
}

# Source the subcommand script exactly once per shell session.
# Uses `_MG_INCLUDE_GUARD_SUBCOMMAND_SCRIPTS` as an include guard map.
function _load_subcommand_script() {
  local subcommand="${1}"
  local script_path

  script_path="$(_subcommand_script_path "${subcommand}")" || return 1

  if [[ "${_MG_INCLUDE_GUARD_SUBCOMMAND_SCRIPTS[${subcommand}]:-}" == "${script_path}" ]]; then
    return 0
  fi

  if [[ ! -f "${script_path}" ]]; then
    echo "Unable to locate subcommand script for ${subcommand}: ${script_path}"
    return 1
  fi

  # shellcheck source=/dev/null
  . "${script_path}" || return 1
  _MG_INCLUDE_GUARD_SUBCOMMAND_SCRIPTS["${subcommand}"]="${script_path}"
}

# Ensure the script is loaded, then dispatch to `_cmd_<subcommand>`.
# Command names with dashes map to function names with underscores.
function _run_subcommand() {
  local subcommand="${1}"
  shift

  _load_subcommand_script "${subcommand}" || return 1

  local function_name="_cmd_${subcommand//-/_}"
  if ! declare -F "${function_name}" 1>/dev/null 2>&1; then
    echo "Subcommand handler not found: ${function_name}"
    return 1
  fi

  "${function_name}" "$@"
}

function my_git_main() {
  local subcommand="${1:-}"
  local resolved_subcommand
  local verbose_enabled=0
  local status

  if [[ "${MG_GIT_VERBOSE:-0}" == "1" ]]; then
    set -x
    verbose_enabled=1
  fi

  shift || true

  resolved_subcommand="$(_resolve_subcommand_alias "${subcommand}")"

  case "${resolved_subcommand}" in
  --short-help)
    _usage_main --short
    status=$?
    ;;
  __complete-metadata)
    _print_completion_metadata
    status=0
    ;;
  update-commit-date)
    _run_subcommand "update-commit-date" "$@"
    status=$?
    ;;
  init)
    _run_subcommand "init" "$@"
    status=$?
    ;;
  clone)
    _run_subcommand "clone" "$@"
    status=$?
    ;;
  show-ignored)
    _run_subcommand "show-ignored" "$@"
    status=$?
    ;;
  show-untracked)
    _run_subcommand "show-untracked" "$@"
    status=$?
    ;;
  switch)
    _run_subcommand "switch" "$@"
    status=$?
    ;;
  new-branch)
    _run_subcommand "new-branch" "$@"
    status=$?
    ;;
  self-branch)
    _run_subcommand "self-branch" "$@"
    status=$?
    ;;
  alien-branch)
    _run_subcommand "alien-branch" "$@"
    status=$?
    ;;
  info)
    _run_subcommand "info" "$@"
    status=$?
    ;;
  path)
    _run_subcommand "path" "$@"
    status=$?
    ;;
  remove-worktree)
    _run_subcommand "remove-worktree" "$@"
    status=$?
    ;;
  remove-branch)
    _run_subcommand "remove-branch" "$@"
    status=$?
    ;;
  prune)
    _run_subcommand "prune" "$@"
    status=$?
    ;;
  help | --help | -h | "")
    if [[ "${resolved_subcommand}" == "-h" && $# -eq 0 ]]; then
      _usage_main --short
    else
      _usage_main "$@"
    fi
    status=$?
    ;;
  *)
    echo "Unknown command: ${subcommand}"
    _usage_main
    status=1
    ;;
  esac

  if [[ "${verbose_enabled}" -eq 1 ]]; then
    set +x
  fi

  return "${status}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  my_git_main "$@"
fi
